pipeline {
    agent any

    stages {
        stage('checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/nsr94/hello-world.git'
                echo 'Building...'
            }
        }
        stage('maven') {
            agent {
                docker {
                    image 'maven:3.9-eclipse-temurin-11'
                    args '-v /root/.m2:/root/.m2'
                }
            }
            steps {
                sh 'mvn -B clean install'
            }
        }
    }
}
